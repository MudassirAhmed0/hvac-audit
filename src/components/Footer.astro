---
const year = new Date().getFullYear();
---

<footer class="bg-surface border-t border-rule px-6 md:px-12 lg:px-16 py-12" data-theme="dark">
  <div class="flex flex-col md:flex-row justify-between items-center gap-6">
    <div class="flex items-center gap-2.5">
      <svg width="24" height="24" viewBox="0 0 32 32" aria-hidden="true">
        <rect width="32" height="32" rx="8" fill="#0b1220"/>
        <rect width="32" height="32" rx="8" fill="none" stroke="#253449" stroke-width="1"/>
        <path d="M8 22a8 8 0 0 1 16 0" fill="none" stroke="#253449" stroke-width="2" stroke-linecap="round"/>
        <path d="M8 22a8 8 0 0 1 12.5-3.5" fill="none" stroke="#0ea5e9" stroke-width="2" stroke-linecap="round"/>
        <line x1="16" y1="22" x2="20" y2="16" stroke="#f1f5f9" stroke-width="2" stroke-linecap="round"/>
        <circle cx="16" cy="22" r="1.5" fill="#0ea5e9"/>
      </svg>
      <span class="text-sm font-semibold tracking-tight">HVAC Audit</span>
    </div>

    <div class="flex items-center gap-8">
      <a
        href="/blog"
        class="text-sm text-ink-secondary hover:text-accent transition-colors duration-300"
      >
        Blog
      </a>
      <a
        href="/reports"
        class="text-sm text-ink-secondary hover:text-accent transition-colors duration-300"
      >
        Reports
      </a>
      <a
        href="/about"
        class="text-sm text-ink-secondary hover:text-accent transition-colors duration-300"
      >
        About
      </a>
      <a
        href="mailto:hello@hvac-audit.co"
        class="text-sm text-ink-secondary hover:text-accent transition-colors duration-300"
      >
        hello@hvac-audit.co
      </a>
    </div>

    <div class="flex items-center gap-6">
      <a href="/privacy" class="text-xs text-ink-muted hover:text-ink-secondary transition-colors duration-300">Privacy</a>
      <a href="/terms" class="text-xs text-ink-muted hover:text-ink-secondary transition-colors duration-300">Terms</a>
      <p class="text-xs text-ink-muted">
        &copy; {year} HVAC Audit
      </p>
    </div>
  </div>
</footer>
