---
const problems = [
  {
    num: "01",
    stat: 18.4,
    suffix: "s",
    label: "Average Load Time",
    description: "The average HVAC website we audited takes 18.4 seconds to load. Google recommends under 3. Every second over costs you 7% in conversions.",
    severity: "critical",
  },
  {
    num: "02",
    stat: 60,
    suffix: "%",
    label: "No SSL Certificate",
    description: "6 out of 10 HVAC sites we scanned have no SSL. Chrome flags these as 'Not Secure' — your customers see a warning before they see your business.",
    severity: "critical",
  },
  {
    num: "03",
    stat: 40,
    suffix: "%",
    label: "No Clear CTA",
    description: "40% of HVAC websites have no obvious call-to-action. Visitors land, see no 'Book Now' or 'Call Us' button, and leave. That's money walking out the door.",
    severity: "high",
  },
  {
    num: "04",
    stat: 50,
    suffix: "%",
    label: "No Contact Form",
    description: "Half the sites we audited have no contact form at all. If a customer can't reach you in 10 seconds, they're calling your competitor.",
    severity: "high",
  },
  {
    num: "05",
    stat: 0,
    suffix: "",
    label: "No Reviews Displayed",
    description: "HVAC businesses average 4.85 stars on Google — but almost none display those reviews on their website. You're sitting on social proof and not using it.",
    severity: "medium",
  },
  {
    num: "06",
    stat: 0,
    suffix: "",
    label: "No SEO Meta Tags",
    description: "Most HVAC sites have no meta descriptions, no title tags, no structured data. Google can't rank what it can't read. You're invisible to local search.",
    severity: "medium",
  },
];

const severityColors: Record<string, string> = {
  critical: "bg-danger",
  high: "bg-warning",
  medium: "bg-ink-muted",
};
---

<section
  class="section-over-hero bg-surface-alt py-20 md:py-44 px-6 md:px-12 lg:px-16 relative border-t border-rule"
  data-theme="dark"
>
  <div class="flex flex-col lg:flex-row gap-12 lg:gap-20 mb-16 md:mb-24">
    <div class="lg:w-1/3">
      <p data-reveal class="text-xs text-danger font-mono tracking-widest uppercase flex items-center gap-2">
        <span class="w-1.5 h-1.5 rounded-full bg-danger"></span>
        The Digital Bleeding
      </p>
    </div>
    <div class="lg:w-2/3">
      <h2
        data-reveal
        style="--delay: 100ms"
        class="text-3xl md:text-5xl lg:text-[3.5rem] font-bold leading-[0.95] tracking-tight"
      >
        We audited 147 HVAC websites.<br class="hidden md:block" />
        Here's what we <span class="text-danger">found.</span>
      </h2>
    </div>
  </div>

  <div class="space-y-0">
    {
      problems.map((problem, i) => (
        <div
          class="border-t border-rule-light py-8 md:py-10 group"
          data-reveal
          style={`--delay: ${i * 80}ms`}
        >
          <div class="flex flex-col md:flex-row md:items-start gap-6 md:gap-12">
            <div class="flex items-start gap-5 md:w-1/3 shrink-0">
              <!-- Severity bar -->
              <div class="flex flex-col items-center gap-3 pt-1">
                <span class="text-[10px] font-mono text-ink-muted">{problem.num}</span>
                <div class={`w-0.5 h-8 rounded-full ${severityColors[problem.severity]}`}></div>
              </div>
              <div>
                {problem.stat > 0 ? (
                  <span class={`text-4xl md:text-5xl font-bold tracking-tight ${problem.severity === "critical" ? "text-danger" : "text-warning"}`}>
                    <span data-counter={problem.stat} data-suffix={problem.suffix}>0{problem.suffix}</span>
                  </span>
                ) : (
                  <span class={`text-sm font-mono uppercase tracking-wider ${problem.severity === "high" ? "text-warning" : "text-ink-muted"}`}>
                    Missing
                  </span>
                )}
                <span class="block text-sm font-medium text-ink mt-1">{problem.label}</span>
              </div>
            </div>
            <p class="text-ink-secondary text-base md:text-[1.0625rem] leading-relaxed md:w-2/3 max-w-xl">
              {problem.description}
            </p>
          </div>
        </div>
      ))
    }
    <div class="border-t border-rule-light" data-reveal-line style="--delay: 480ms"></div>
  </div>
</section>
