---
import Base from "../../layouts/Base.astro";
import { reports } from "../../data/reports";

const formspreeUrl = import.meta.env.PUBLIC_FORMSPREE_URL || "";

const audits = reports.map((r) => {
  const circumference = 2 * Math.PI * 20;
  const offset = circumference - (r.totalScore / 100) * circumference;
  const scoreColor =
    r.totalScore >= 80 ? "#10b981" : r.totalScore >= 60 ? "#f59e0b" : "#f87171";
  return { ...r, scoreColor, circumference, offset };
});

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: "HVAC Website Audit Reports",
  description: "Real audit reports from HVAC businesses. See the exact issues costing contractors money online.",
  url: "https://hvacaudit.co/reports",
};
---

<Base
  title="Audit Reports — HVAC Audit"
  description="Real audit reports from HVAC businesses. See the exact issues costing contractors money online."
  jsonLd={jsonLd}
>
  <section class="pt-28 pb-20 sm:pt-32 sm:pb-28">
    <div class="px-6 md:px-12 lg:px-16">
      <!-- Header (full width) -->
      <div data-reveal class="mb-12">
        <p class="font-mono text-xs tracking-widest uppercase text-ink-muted mb-3">
          Audit Reports
        </p>
        <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold tracking-tight leading-[1.1]">
          Real reports.<br /><span class="text-accent">Real problems found.</span>
        </h1>
        <p class="mt-4 text-ink-secondary text-lg leading-relaxed max-w-2xl" data-reveal style="--delay:80ms">
          Every report below is a real HVAC business. Click to see the full diagnostic with issues, dollar impact, and recommended fixes.
        </p>
      </div>

      <div class="flex gap-6 xl:gap-8">
        <!-- Left: reports grid -->
        <div class="min-w-0 flex-1">
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
            {audits.map((audit, i) => (
              <a
                href={`/report/${audit.slug}/`}
                data-reveal
                style={`--delay: ${(i + 1) * 80}ms`}
                class="group rounded-xl border border-rule bg-surface-card hover:border-accent/40 transition-colors duration-300 p-6 flex flex-col gap-4"
              >
                <div class="flex items-center gap-4">
                  <div class="relative w-12 h-12 flex-none">
                    <svg viewBox="0 0 48 48" class="w-full h-full -rotate-90">
                      <circle cx="24" cy="24" r="20" fill="none" stroke="currentColor" stroke-width="3" class="text-rule" />
                      <circle
                        cx="24" cy="24" r="20"
                        fill="none"
                        stroke={audit.scoreColor}
                        stroke-width="3"
                        stroke-linecap="round"
                        stroke-dasharray={audit.circumference}
                        stroke-dashoffset={audit.offset}
                      />
                    </svg>
                    <div class="absolute inset-0 flex items-center justify-center">
                      <span class="text-xs font-bold" style={`color:${audit.scoreColor}`}>{audit.totalScore}</span>
                    </div>
                  </div>
                  <div class="min-w-0">
                    <p class="font-semibold text-sm truncate group-hover:text-accent transition-colors">{audit.name}</p>
                    <p class="text-xs text-ink-muted font-mono">{audit.domain}</p>
                  </div>
                </div>

                <div class="flex items-center gap-3 flex-wrap">
                  <span class="text-xs font-mono text-ink-muted">
                    {audit.gapSummary.length} issues
                  </span>
                  <span class="w-px h-3 bg-rule"></span>
                  <span class="text-xs font-mono text-danger font-semibold">
                    ~{audit.impactEstimate.missedLeads} missed leads/mo
                  </span>
                  <span class="w-px h-3 bg-rule"></span>
                  <span class="text-xs font-mono text-ink-muted">
                    {audit.rating}&#9733; ({audit.reviewCount.toLocaleString()})
                  </span>
                </div>

                <div class="border-t border-rule pt-3">
                  <p class="text-xs text-ink-muted font-mono uppercase tracking-wide mb-2">#1 Issue</p>
                  <p class="text-sm text-ink-secondary leading-relaxed line-clamp-2">
                    {audit.businessSummary.topThreeGaps[0]}
                  </p>
                </div>

                <div class="mt-auto pt-2 flex items-center gap-1.5 text-xs font-semibold text-accent opacity-0 group-hover:opacity-100 transition-opacity">
                  View full report
                  <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                  </svg>
                </div>
              </a>
            ))}
          </div>
        </div>

        <!-- Right: sticky form (desktop only) -->
        <aside class="hidden lg:block w-[300px] xl:w-[320px] flex-none">
          <div class="sticky top-24" data-reveal style="--delay:300ms">
            <div class="rounded-xl border border-rule bg-surface-alt/60 p-6">
              <p class="text-lg font-bold tracking-tight mb-1">
                Free audit
              </p>
              <p class="text-xs text-ink-muted mb-5">
                Full report in 48 hours. No strings.
              </p>

              <form
                id="reports-form"
                class="flex flex-col gap-3"
                action={formspreeUrl}
                method="POST"
                aria-label="Request a free HVAC website audit"
              >
                <input type="hidden" name="_subject" value="Reports Page Audit Request" />
                <input type="text" name="_gotcha" style="display:none" />
                <input
                  type="text"
                  name="business_name"
                  placeholder="Business name"
                  required
                  autocomplete="organization"
                  class="w-full px-4 py-3 rounded-lg bg-surface border border-rule-light text-ink placeholder-ink-faint text-sm focus:outline-none focus:border-accent focus:ring-1 focus:ring-accent transition-all duration-300"
                />
                <input
                  type="text"
                  name="website"
                  placeholder="yoursite.com"
                  required
                  autocomplete="url"
                  class="w-full px-4 py-3 rounded-lg bg-surface border border-rule-light text-ink placeholder-ink-faint text-sm focus:outline-none focus:border-accent focus:ring-1 focus:ring-accent transition-all duration-300"
                />
                <input
                  type="email"
                  name="email"
                  placeholder="Email for report"
                  required
                  autocomplete="email"
                  class="w-full px-4 py-3 rounded-lg bg-surface border border-rule-light text-ink placeholder-ink-faint text-sm focus:outline-none focus:border-accent focus:ring-1 focus:ring-accent transition-all duration-300"
                />
                <button
                  type="submit"
                  id="reports-submit"
                  class="w-full px-5 py-3.5 rounded-lg bg-accent text-[#0b1220] text-sm font-semibold hover:bg-accent-hover transition-colors duration-300 cursor-pointer"
                >
                  Run My Free Audit
                </button>
              </form>

              <div id="reports-success" class="hidden text-center py-6">
                <div class="w-10 h-10 rounded-full bg-success/15 flex items-center justify-center mx-auto mb-3">
                  <svg class="w-5 h-5 text-success" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                  </svg>
                </div>
                <p class="text-sm font-semibold mb-1">We're on it.</p>
                <p class="text-xs text-ink-muted">Report in your inbox within 48 hours.</p>
              </div>

              <div class="mt-4 pt-4 border-t border-rule/60 space-y-2">
                <div class="flex items-center gap-2">
                  <svg width="12" height="12" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                    <path d="M13.5 4.5L6.5 11.5L2.5 7.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-success" />
                  </svg>
                  <span class="text-[11px] text-ink-muted">No credit card</span>
                </div>
                <div class="flex items-center gap-2">
                  <svg width="12" height="12" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                    <path d="M13.5 4.5L6.5 11.5L2.5 7.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-success" />
                  </svg>
                  <span class="text-[11px] text-ink-muted">No sales call</span>
                </div>
                <div class="flex items-center gap-2">
                  <svg width="12" height="12" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                    <path d="M13.5 4.5L6.5 11.5L2.5 7.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-success" />
                  </svg>
                  <span class="text-[11px] text-ink-muted">Manually reviewed</span>
                </div>
              </div>
            </div>
          </div>
        </aside>
      </div>

      <!-- Mobile form -->
      <div class="lg:hidden mt-16 rounded-xl border border-accent/20 bg-accent/5 px-6 py-8" data-reveal>
        <p class="text-xl font-bold tracking-tight mb-1">
          Want to know your score?
        </p>
        <p class="text-sm text-ink-secondary mb-5">
          Drop your URL — full report in 48 hours.
        </p>
        <form
          id="reports-form-mobile"
          class="flex flex-col gap-3"
          action={formspreeUrl}
          method="POST"
        >
          <input type="hidden" name="_subject" value="Reports Page Audit Request (Mobile)" />
          <input type="text" name="_gotcha" style="display:none" />
          <input type="text" name="business_name" placeholder="Business name" required class="w-full px-4 py-3.5 rounded-lg bg-surface border border-rule-light text-ink placeholder-ink-faint text-sm focus:outline-none focus:border-accent focus:ring-1 focus:ring-accent transition-all duration-300" />
          <input type="text" name="website" placeholder="yoursite.com" required class="w-full px-4 py-3.5 rounded-lg bg-surface border border-rule-light text-ink placeholder-ink-faint text-sm focus:outline-none focus:border-accent focus:ring-1 focus:ring-accent transition-all duration-300" />
          <input type="email" name="email" placeholder="Email for report" required class="w-full px-4 py-3.5 rounded-lg bg-surface border border-rule-light text-ink placeholder-ink-faint text-sm focus:outline-none focus:border-accent focus:ring-1 focus:ring-accent transition-all duration-300" />
          <button type="submit" id="reports-submit-mobile" class="w-full px-5 py-3.5 rounded-lg bg-accent text-[#0b1220] text-sm font-semibold hover:bg-accent-hover transition-colors duration-300 cursor-pointer">
            Run My Free Audit
          </button>
        </form>
        <div id="reports-success-mobile" class="hidden text-center py-6">
          <p class="text-sm font-semibold mb-1">We're on it.</p>
          <p class="text-xs text-ink-muted">Report in your inbox within 48 hours.</p>
        </div>
      </div>
    </div>
  </section>

  <script>
    function setupForm(formId: string, successId: string, submitId: string) {
      const form = document.getElementById(formId) as HTMLFormElement | null;
      const success = document.getElementById(successId);
      const btn = document.getElementById(submitId) as HTMLButtonElement | null;
      if (!form || !success || !btn) return;

      form.addEventListener("submit", async (e) => {
        e.preventDefault();
        if (btn.disabled) return;
        btn.textContent = "Sending...";
        btn.disabled = true;
        try {
          const res = await fetch(form.action, {
            method: "POST",
            body: new FormData(form),
            headers: { Accept: "application/json" },
          });
          if (res.ok) {
            form.classList.add("hidden");
            success.classList.remove("hidden");
          } else {
            btn.textContent = "Something went wrong";
            btn.disabled = false;
            setTimeout(() => { btn.textContent = "Run My Free Audit"; }, 3000);
          }
        } catch {
          btn.textContent = "Something went wrong";
          btn.disabled = false;
          setTimeout(() => { btn.textContent = "Run My Free Audit"; }, 3000);
        }
      });
    }

    setupForm("reports-form", "reports-success", "reports-submit");
    setupForm("reports-form-mobile", "reports-success-mobile", "reports-submit-mobile");
  </script>
</Base>
