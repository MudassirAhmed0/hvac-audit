---
import Base from "../../layouts/Base.astro";
import CTAForm from "../../components/CTAForm.astro";
import { painPages, type PainPage } from "../../data/pain-pages";
import { reports, severityColors, type Report } from "../../data/reports";
import marketData from "../../data/market-data.json";

export function getStaticPaths() {
  return painPages.map((page) => ({
    params: { pain: page.slug },
    props: { page },
  }));
}

const { page } = Astro.props as { page: PainPage };

// Find real reports matching this diagnostic type
const matchingReports = reports.filter(
  (r) => r.businessSummary?.diagnosticType === page.diagnosticType
);

const siteUrl = import.meta.env.SITE_URL || "https://hvacaudit.co";
const pageUrl = `${siteUrl}/${page.slug}/`;

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    name: page.title,
    description: page.metaDescription,
    url: pageUrl,
    publisher: { "@type": "Organization", name: "HVAC Audit", url: siteUrl },
    author: {
      "@type": "Person",
      name: "Mudassir Ahmed",
      url: `${siteUrl}/about/`,
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "Home", item: siteUrl },
      { "@type": "ListItem", position: 2, name: page.h1.split("\n")[0], item: pageUrl },
    ],
  },
];

// Diagnostic type colors
const typeColors: Record<string, { accent: string; accentBg: string; accentBorder: string }> = {
  "blind-spender": { accent: "text-red-400", accentBg: "bg-red-500/10", accentBorder: "border-red-500/20" },
  "pretty-and-broken": { accent: "text-orange-400", accentBg: "bg-orange-500/10", accentBorder: "border-orange-500/20" },
  "half-built": { accent: "text-yellow-400", accentBg: "bg-yellow-500/10", accentBorder: "border-yellow-500/20" },
  "invisible": { accent: "text-sky-400", accentBg: "bg-sky-500/10", accentBorder: "border-sky-500/20" },
};
const colors = typeColors[page.diagnosticType] || typeColors["blind-spender"];
---

<Base title={page.title} description={page.metaDescription} jsonLd={jsonLd}>
  <!-- Hero -->
  <section class="relative pt-28 pb-16 sm:pt-36 sm:pb-20 px-6 md:px-12 lg:px-16">
    <div class="absolute top-0 right-0 w-1/2 h-full opacity-[0.03] pointer-events-none"
      style="background: radial-gradient(ellipse at 70% 30%, #0ea5e9, transparent 70%);"
      aria-hidden="true">
    </div>

    <div class="relative z-10">
      <div class="hero-reveal">
        <p class={`text-xs font-mono tracking-widest uppercase ${colors.accent} flex items-center gap-2 mb-6`}>
          <span class={`w-1.5 h-1.5 rounded-full ${colors.accentBg.replace('/10', '')}`}></span>
          HVAC Website Diagnostic
        </p>
        {page.h1.split("\n").map((line, i) => (
          <span
            class={`hero-reveal block text-[clamp(2rem,5vw,4rem)] font-bold leading-[0.95] tracking-tight ${i > 0 ? "text-ink-secondary" : ""}`}
            style={`--delay: ${(i + 1) * 100}ms`}
          >
            {line}
          </span>
        ))}
      </div>

      <p class="hero-reveal mt-8 text-base md:text-lg text-ink-secondary leading-relaxed max-w-2xl" style="--delay: 300ms">
        {page.subtitle}
      </p>

      <div class="hero-reveal mt-8 flex flex-col sm:flex-row items-start sm:items-center gap-6" style="--delay: 400ms">
        <a
          href="#audit"
          class="inline-flex items-center gap-3 px-7 py-3.5 rounded-full bg-accent text-[#0b1220] text-sm font-semibold hover:bg-accent-hover transition-colors duration-300"
        >
          Get Your Free Diagnostic
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
            <path d="M2 7h10M8 3l4 4-4 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </a>
        <div class={`flex items-center gap-3 rounded-lg ${colors.accentBg} px-4 py-2.5`}>
          <span class={`text-2xl font-bold font-mono ${colors.accent}`}>{page.heroStat}</span>
          <span class="text-xs text-ink-muted font-mono">{page.heroStatLabel}</span>
        </div>
      </div>
    </div>
  </section>

  <!-- What We Find -->
  <section class="py-16 sm:py-24 px-6 md:px-12 lg:px-16 border-t border-rule bg-surface-alt/50">
    <div>
      <h2 class="text-2xl sm:text-4xl font-bold tracking-tight leading-[0.95]" data-reveal>
        {page.sections.whatWeFind.heading}
      </h2>
      <p class="mt-4 text-ink-secondary leading-relaxed max-w-2xl" data-reveal style="--delay:80ms">
        {page.sections.whatWeFind.intro}
      </p>

      <div class="mt-12 space-y-0">
        {page.sections.whatWeFind.findings.map((finding, i) => (
          <div
            class="border-t border-rule-light py-8 md:py-10"
            data-reveal
            style={`--delay: ${i * 80}ms`}
          >
            <div class="flex flex-col md:flex-row md:items-start gap-6 md:gap-12">
              <div class="flex items-start gap-5 md:w-1/3 shrink-0">
                <div class="flex flex-col items-center gap-3 pt-1">
                  <span class="text-[10px] font-mono text-ink-muted">0{i + 1}</span>
                  <div class={`w-0.5 h-8 rounded-full ${i < 2 ? "bg-danger" : "bg-warning"}`}></div>
                </div>
                <div>
                  <span class={`text-3xl md:text-4xl font-bold tracking-tight ${i < 2 ? "text-danger" : "text-warning"}`}>
                    {finding.stat}
                  </span>
                  <span class="block text-sm font-medium text-ink mt-1">{finding.label}</span>
                </div>
              </div>
              <p class="text-ink-secondary text-base leading-relaxed md:w-2/3 max-w-xl">
                {finding.detail}
              </p>
            </div>
          </div>
        ))}
        <div class="border-t border-rule-light"></div>
      </div>
    </div>
  </section>

  <!-- Why It Happens -->
  <section class="py-16 sm:py-24 px-6 md:px-12 lg:px-16 border-t border-rule">
    <div>
      <h2 class="text-2xl sm:text-4xl font-bold tracking-tight" data-reveal>
        {page.sections.whyItHappens.heading}
      </h2>

      <div class="mt-10 grid grid-cols-1 md:grid-cols-3 gap-0 md:gap-0">
        {page.sections.whyItHappens.reasons.map((reason, i) => (
          <div
            data-reveal
            style={`--delay: ${i * 100}ms`}
            class="relative border-t border-rule-light md:border-t-0 md:border-l md:first:border-l-0 md:border-rule-light"
          >
            <div class="p-6 md:p-8">
              <span class="text-5xl md:text-6xl font-bold tracking-tighter text-ink opacity-[0.06] block leading-none">0{i + 1}</span>
              <h3 class="text-lg md:text-xl font-bold mt-3 mb-3">{reason.title}</h3>
              <p class="text-sm text-ink-secondary leading-relaxed">
                {reason.description}
              </p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Real Reports (if any match) -->
  {matchingReports.length > 0 && (
    <section class="py-16 sm:py-24 px-6 md:px-12 lg:px-16 border-t border-rule bg-surface-alt/50">
      <div>
        <h2 class="text-2xl sm:text-3xl font-bold tracking-tight" data-reveal>
          Real HVAC Businesses With This Problem
        </h2>
        <p class="mt-3 text-ink-secondary" data-reveal style="--delay:60ms">
          These are actual audits we've conducted. See the full diagnostic.
        </p>

        <div class="mt-8 grid grid-cols-1 sm:grid-cols-2 gap-4">
          {matchingReports.slice(0, 4).map((r, i) => {
            const scoreColor = r.websiteQualityScore >= 60 ? "text-success" : r.websiteQualityScore >= 40 ? "text-warning" : "text-danger";
            return (
              <a
                href={`/report/${r.slug}/`}
                class="group block rounded-xl border border-rule bg-surface hover:bg-surface-card px-5 py-5 transition-colors duration-300"
                data-reveal
                style={`--delay: ${i * 80}ms`}
              >
                <div class="flex items-start justify-between gap-3">
                  <div class="min-w-0">
                    <p class="font-semibold text-sm truncate group-hover:text-accent transition-colors">{r.name}</p>
                    <p class="text-xs text-ink-muted mt-1">{r.city}, {r.state}</p>
                  </div>
                  <div class="flex-none text-right">
                    <span class={`text-xl font-bold font-mono ${scoreColor}`}>{r.websiteQualityScore}</span>
                    <span class="text-[10px] text-ink-muted block font-mono">/100</span>
                  </div>
                </div>
                <div class="mt-3 flex items-center gap-3">
                  <span class="text-xs text-ink-muted">{r.gapSummary.length} issues</span>
                  <span class="text-xs text-ink-muted">&middot;</span>
                  <span class="text-xs text-danger">{r.impactEstimate.missedLeads} missed leads/mo</span>
                </div>
              </a>
            );
          })}
        </div>
      </div>
    </section>
  )}

  <!-- What to Fix -->
  <section class="py-16 sm:py-24 px-6 md:px-12 lg:px-16 border-t border-rule">
    <div>
      <h2 class="text-2xl sm:text-4xl font-bold tracking-tight" data-reveal>
        {page.sections.whatToFix.heading}
      </h2>
      <p class="mt-4 text-ink-secondary leading-relaxed max-w-2xl" data-reveal style="--delay:80ms">
        {page.sections.whatToFix.intro}
      </p>

      <div class="mt-10 space-y-4">
        {page.sections.whatToFix.steps.map((step, i) => (
          <div
            class="rounded-xl border border-rule bg-surface-alt/40 px-5 py-5 sm:px-6 sm:py-6"
            data-reveal
            style={`--delay: ${i * 80}ms`}
          >
            <div class="flex items-start gap-4">
              <span class="flex-none mt-0.5 w-8 h-8 rounded-lg bg-accent/15 text-accent flex items-center justify-center font-bold text-sm font-mono">
                {i + 1}
              </span>
              <div class="flex-1">
                <h3 class="font-semibold text-base sm:text-lg">{step.title}</h3>
                <p class="mt-2 text-sm text-ink-secondary leading-relaxed">{step.description}</p>
                <div class="mt-3 flex items-center gap-4 flex-wrap">
                  <div class="flex items-center gap-1.5">
                    <span class="text-xs font-mono text-ink-muted">Effort:</span>
                    <span class="text-sm font-medium text-accent">{step.effort}</span>
                  </div>
                  <div class="flex items-center gap-1.5">
                    <span class="text-xs font-mono text-ink-muted">Impact:</span>
                    <span class="text-sm font-medium text-success">{step.impact}</span>
                  </div>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- City Reports -->
  <section class="py-16 sm:py-24 px-6 md:px-12 lg:px-16 border-t border-rule bg-surface-alt/50">
    <h2 class="text-2xl sm:text-3xl font-bold tracking-tight" data-reveal>
      See This Problem by City
    </h2>
    <p class="mt-3 text-ink-secondary" data-reveal style="--delay:60ms">
      We break down the data for every market we've audited.
    </p>

    <div class="mt-8 grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-3">
      {(marketData.cities as any[]).slice(0, 12).map((city, i) => {
        const scoreColor = city.avgDeepScore >= 60 ? "text-success" : city.avgDeepScore >= 40 ? "text-warning" : "text-danger";
        return (
          <a
            href={`/${page.slug}/${city.slug}/`}
            class="group block rounded-lg border border-rule bg-surface hover:bg-surface-card px-4 py-3 transition-colors duration-300"
            data-reveal
            style={`--delay: ${i * 40}ms`}
          >
            <p class="font-medium text-sm group-hover:text-accent transition-colors">{city.city}, {city.state}</p>
            <div class="mt-1 flex items-center gap-2">
              <span class={`text-sm font-bold font-mono ${scoreColor}`}>{city.avgDeepScore}</span>
              <span class="text-[10px] text-ink-muted font-mono">/100 avg</span>
            </div>
          </a>
        );
      })}
    </div>

    {(marketData.cities as any[]).length > 12 && (
      <details class="mt-4" data-reveal style="--delay:200ms">
        <summary class="text-sm text-ink-muted hover:text-accent cursor-pointer transition-colors font-mono">
          + {(marketData.cities as any[]).length - 12} more cities
        </summary>
        <div class="mt-3 grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-3">
          {(marketData.cities as any[]).slice(12).map((city, i) => {
            const scoreColor = city.avgDeepScore >= 60 ? "text-success" : city.avgDeepScore >= 40 ? "text-warning" : "text-danger";
            return (
              <a
                href={`/${page.slug}/${city.slug}/`}
                class="group block rounded-lg border border-rule bg-surface hover:bg-surface-card px-4 py-3 transition-colors duration-300"
              >
                <p class="font-medium text-sm group-hover:text-accent transition-colors">{city.city}, {city.state}</p>
                <div class="mt-1 flex items-center gap-2">
                  <span class={`text-sm font-bold font-mono ${scoreColor}`}>{city.avgDeepScore}</span>
                  <span class="text-[10px] text-ink-muted font-mono">/100 avg</span>
                </div>
              </a>
            );
          })}
        </div>
      </details>
    )}
  </section>

  <!-- Bottom CTA context -->
  <section class="py-10 px-6 md:px-12 lg:px-16 border-t border-rule bg-accent/5">
    <div data-reveal>
      <p class="text-ink-secondary leading-relaxed">
        <span class="font-semibold text-ink">Stop guessing.</span> We'll audit your HVAC website for free and show you exactly what's broken,
        what it's costing you, and what to fix first. 48-hour turnaround.
      </p>
    </div>
  </section>

  <CTAForm />
</Base>
