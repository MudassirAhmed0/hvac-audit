---
import Base from "../../layouts/Base.astro";
import ReportPreview from "../../components/ReportPreview.astro";
import { getCollection, render } from "astro:content";

const formspreeUrl = import.meta.env.PUBLIC_FORMSPREE_URL || "";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { slug: post.id.replace(/\.md$/, "") },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const siteUrl = import.meta.env.SITE_URL || Astro.site?.href?.replace(/\/$/, "") || "https://hvac-audit.co";

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    headline: post.data.title,
    description: post.data.description,
    image: `${siteUrl}${post.data.cover}`,
    datePublished: post.data.date.toISOString(),
    author: {
      "@type": "Person",
      name: "Mudassir Ahmed",
    },
    publisher: {
      "@type": "Organization",
      name: "HVAC Audit",
      url: siteUrl,
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "Home", item: siteUrl },
      { "@type": "ListItem", position: 2, name: "Blog", item: `${siteUrl}/blog` },
      { "@type": "ListItem", position: 3, name: post.data.title },
    ],
  },
];
---

<Base
  title={`${post.data.title} — HVAC Audit`}
  description={post.data.description}
  ogImage={post.data.cover}
  jsonLd={jsonLd}
>
  <article>
    <div class="px-6 md:px-12 lg:px-16 pt-28 sm:pt-32 pb-20 sm:pb-28">
      <!-- Header (full width) -->
      <div class="mb-10">
        <a
          href="/blog"
          class="inline-flex items-center gap-1.5 text-xs font-mono text-ink-muted hover:text-accent transition-colors mb-6"
          data-reveal
        >
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
          </svg>
          All posts
        </a>
        <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold tracking-tight leading-[1.1]" data-reveal style="--delay:60ms">
          {post.data.title}
        </h1>
        <p class="mt-4 text-ink-secondary text-lg leading-relaxed max-w-3xl" data-reveal style="--delay:120ms">
          {post.data.description}
        </p>
        <div class="mt-5 flex items-center gap-3 text-xs font-mono text-ink-muted" data-reveal style="--delay:160ms">
          <time datetime={post.data.date.toISOString().slice(0, 10)}>
            {post.data.date.toLocaleDateString("en-US", { month: "long", day: "numeric", year: "numeric" })}
          </time>
          <span class="text-rule">|</span>
          <span>{post.data.readTime}</span>
        </div>
      </div>

      <div class="flex gap-6 xl:gap-8">
        <!-- Left: image + content -->
        <div class="min-w-0 flex-1">
          <!-- Cover image -->
          <div class="rounded-xl overflow-hidden border border-rule shadow-[0_20px_60px_rgba(0,0,0,0.4)]" data-reveal style="--delay:200ms">
            <img
              src={post.data.cover}
              alt={post.data.title}
              width="1080"
              height="1080"
              class="w-full aspect-[2/1] object-cover"
              loading="eager"
            />
          </div>

          <!-- Content -->
          <div class="prose mt-10" data-reveal style="--delay:100ms">
            <Content />
          </div>
        </div>

        <!-- Right: sticky form (desktop only) -->
        <aside class="hidden lg:block w-[300px] xl:w-[320px] flex-none">
          <div class="sticky top-24" data-reveal style="--delay:300ms">
            <div class="rounded-xl border border-rule bg-surface-alt/60 p-6">
              <p class="text-lg font-bold tracking-tight mb-1">
                Free audit
              </p>
              <p class="text-xs text-ink-muted mb-5">
                Full report in 48 hours. No strings.
              </p>

              <form
                id="blog-audit-form"
                class="flex flex-col gap-3"
                action={formspreeUrl}
                method="POST"
                aria-label="Request a free HVAC website audit"
              >
                <input type="hidden" name="_subject" value="Blog Audit Request" />
                <input type="text" name="_gotcha" style="display:none" />
                <input
                  type="text"
                  name="business_name"
                  placeholder="Business name"
                  required
                  autocomplete="organization"
                  class="w-full px-4 py-3 rounded-lg bg-surface border border-rule-light text-ink placeholder-ink-faint text-sm focus:outline-none focus:border-accent focus:ring-1 focus:ring-accent transition-all duration-300"
                />
                <input
                  type="text"
                  name="website"
                  placeholder="yoursite.com"
                  required
                  autocomplete="url"
                  class="w-full px-4 py-3 rounded-lg bg-surface border border-rule-light text-ink placeholder-ink-faint text-sm focus:outline-none focus:border-accent focus:ring-1 focus:ring-accent transition-all duration-300"
                />
                <input
                  type="email"
                  name="email"
                  placeholder="Email for report"
                  required
                  autocomplete="email"
                  class="w-full px-4 py-3 rounded-lg bg-surface border border-rule-light text-ink placeholder-ink-faint text-sm focus:outline-none focus:border-accent focus:ring-1 focus:ring-accent transition-all duration-300"
                />
                <button
                  type="submit"
                  id="blog-audit-submit"
                  class="w-full px-5 py-3.5 rounded-lg bg-accent text-[#0b1220] text-sm font-semibold hover:bg-accent-hover transition-colors duration-300 cursor-pointer"
                >
                  Run My Free Audit
                </button>
              </form>

              <!-- Success -->
              <div id="blog-audit-success" class="hidden text-center py-6">
                <div class="w-10 h-10 rounded-full bg-success/15 flex items-center justify-center mx-auto mb-3">
                  <svg class="w-5 h-5 text-success" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                  </svg>
                </div>
                <p class="text-sm font-semibold mb-1">We're on it.</p>
                <p class="text-xs text-ink-muted">Report in your inbox within 48 hours.</p>
              </div>

              <!-- Trust -->
              <div class="mt-4 pt-4 border-t border-rule/60 space-y-2">
                <div class="flex items-center gap-2">
                  <svg width="12" height="12" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                    <path d="M13.5 4.5L6.5 11.5L2.5 7.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-success" />
                  </svg>
                  <span class="text-[11px] text-ink-muted">No credit card</span>
                </div>
                <div class="flex items-center gap-2">
                  <svg width="12" height="12" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                    <path d="M13.5 4.5L6.5 11.5L2.5 7.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-success" />
                  </svg>
                  <span class="text-[11px] text-ink-muted">No sales call</span>
                </div>
                <div class="flex items-center gap-2">
                  <svg width="12" height="12" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                    <path d="M13.5 4.5L6.5 11.5L2.5 7.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-success" />
                  </svg>
                  <span class="text-[11px] text-ink-muted">Manually reviewed</span>
                </div>
              </div>
            </div>
          </div>
        </aside>
      </div>

      <!-- Mobile form (below content) -->
      <div class="lg:hidden mt-16 rounded-xl border border-accent/20 bg-accent/5 px-6 py-8" data-reveal>
        <p class="text-xl font-bold tracking-tight mb-1">
          Want to know your score?
        </p>
        <p class="text-sm text-ink-secondary mb-5">
          Drop your URL — full report in 48 hours.
        </p>
        <form
          id="blog-audit-form-mobile"
          class="flex flex-col gap-3"
          action={formspreeUrl}
          method="POST"
        >
          <input type="hidden" name="_subject" value="Blog Audit Request (Mobile)" />
          <input type="text" name="_gotcha" style="display:none" />
          <input
            type="text"
            name="business_name"
            placeholder="Business name"
            required
            class="w-full px-4 py-3.5 rounded-lg bg-surface border border-rule-light text-ink placeholder-ink-faint text-sm focus:outline-none focus:border-accent focus:ring-1 focus:ring-accent transition-all duration-300"
          />
          <input
            type="text"
            name="website"
            placeholder="yoursite.com"
            required
            class="w-full px-4 py-3.5 rounded-lg bg-surface border border-rule-light text-ink placeholder-ink-faint text-sm focus:outline-none focus:border-accent focus:ring-1 focus:ring-accent transition-all duration-300"
          />
          <input
            type="email"
            name="email"
            placeholder="Email for report"
            required
            class="w-full px-4 py-3.5 rounded-lg bg-surface border border-rule-light text-ink placeholder-ink-faint text-sm focus:outline-none focus:border-accent focus:ring-1 focus:ring-accent transition-all duration-300"
          />
          <button
            type="submit"
            id="blog-audit-submit-mobile"
            class="w-full px-5 py-3.5 rounded-lg bg-accent text-[#0b1220] text-sm font-semibold hover:bg-accent-hover transition-colors duration-300 cursor-pointer"
          >
            Run My Free Audit
          </button>
        </form>
        <div id="blog-audit-success-mobile" class="hidden text-center py-6">
          <p class="text-sm font-semibold mb-1">We're on it.</p>
          <p class="text-xs text-ink-muted">Report in your inbox within 48 hours.</p>
        </div>
      </div>
    </div>
  </article>

  <ReportPreview />

  <script>
    function setupForm(formId: string, successId: string, submitId: string) {
      const form = document.getElementById(formId) as HTMLFormElement | null;
      const success = document.getElementById(successId);
      const btn = document.getElementById(submitId) as HTMLButtonElement | null;
      if (!form || !success || !btn) return;

      form.addEventListener("submit", async (e) => {
        e.preventDefault();
        if (btn.disabled) return;
        btn.textContent = "Sending...";
        btn.disabled = true;
        try {
          const res = await fetch(form.action, {
            method: "POST",
            body: new FormData(form),
            headers: { Accept: "application/json" },
          });
          if (res.ok) {
            form.classList.add("hidden");
            success.classList.remove("hidden");
          } else {
            btn.textContent = "Something went wrong";
            btn.disabled = false;
            setTimeout(() => { btn.textContent = "Run My Free Audit"; }, 3000);
          }
        } catch {
          btn.textContent = "Something went wrong";
          btn.disabled = false;
          setTimeout(() => { btn.textContent = "Run My Free Audit"; }, 3000);
        }
      });
    }

    setupForm("blog-audit-form", "blog-audit-success", "blog-audit-submit");
    setupForm("blog-audit-form-mobile", "blog-audit-success-mobile", "blog-audit-submit-mobile");
  </script>
</Base>
